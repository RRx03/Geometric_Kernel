{
  "display": {
    "width": 1280,
    "height": 720,
    "fullscreen": false,
    "msaa_samples": 4,
    "vsync": true
  },
  "ray_marcher": {
    "max_steps": 128,
    "max_distance": 5.0,
    "min_hit_eps": 3e-5,
    "relative_hit_eps": 3e-4,
    "step_safety_factor": 0.85
  },
  "normals": { "min_eps": 5e-5, "relative_eps": 2e-4 },
  "lighting": {
    "ambient": 0.15,
    "diffuse_strength": 0.75,
    "specular_strength": 0.2,
    "specular_power": 48.0,
    "base_color": [0.75, 0.78, 0.82],
    "background_bottom": [0.12, 0.12, 0.14],
    "background_top": [0.22, 0.22, 0.25]
  },
  "camera": {
    "initial_distance": 0.3,
    "initial_azimuth": 0.5,
    "initial_elevation": 0.3,
    "initial_target": [0.0, 0.0, 0.0],
    "auto_frame": true
  },
  "export": {
    "format": "stl_binary",
    "scale_factor": 1000.0,
    "max_voxels_per_dim": 1024
  },
  "scene": { "file": "scenes/test_nozzle.json", "display_mode": "auto" }
}
